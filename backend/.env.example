# ── Servidor ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=qa_learn
PG_USER=postgres
PG_PASSWORD=tu_password_aqui

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui
JWT_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ── CORS — URL exacta donde se sirve el frontend ──────────────────────────
# Si abres los HTML directamente desde el sistema de archivos:
FRONTEND_URL=null
# Si usas un servidor local (Live Server en VSCode en puerto 5500):
# FRONTEND_URL=http://127.0.0.1:5500
# Si usas http-server en puerto 8080:
# FRONTEND_URL=http://localhost:8080
